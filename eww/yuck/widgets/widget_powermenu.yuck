(defwidget widget_powermenu []
    (box
        (box
            :class "powermenu_root_box"
            
            (box
                :class "powermenu_dock"
                :halign "center"
                :valign "center"
                :width {round(DP_WIDTH / BOX_SIZE_POWERMENU_P_H, 0)}
                :height {round(DP_HEIGHT / BOX_SIZE_POWERMENU_P_V, 0)}

                (module_powermenu)
            )
        )
    ) 
)
